#!/usr/bin/env bash
#
# Raise the LimON Hebrew-transcription endpoint on Nebius for a test/demo.
#
# The endpoint is DOWN by design most of the time: an idle L40S is the only way
# this feature gets expensive. Run this right before you need audio transcribed,
# and tear it down the moment you are done (Nebius web UI, or scripts/endpoint/down).
#
# What it does:
#   1. Create a token-authed, public L40S endpoint from the transcriber image
#      (idempotent: reuses the one recorded in the local state file if it is
#      still alive, so re-running never spins up a second billing endpoint).
#   2. Warm it: retry one POST /transcribe until the container answers. This is
#      also the readiness probe -- only an inference request wakes a cold
#      endpoint, so we never health-ping to probe.
#   3. Save {id,url,token} to the gitignored state file next to this script and
#      print a loud "still billing" reminder with the exact teardown command.
#
# NOT done here (see spec-local/plan/06-ops-endpoint.md):
#   - Pending-backlog re-enqueue: deferred. In the local/manual workflow nothing
#     accumulates on its own; drain by hand via the dev shim if ever needed.
#   - Dead-man switch: none. Teardown is manual and on you.
#
# Nebius is public preview. The command tree and every create/get/delete flag
# below were verified against `nebius ai endpoint ... --help` (CLI 0.12.x), and
# the create flags/values mirror an invocation confirmed to have raised the
# endpoint successfully. The ONE thing not verifiable offline is which JSON field
# holds the endpoint URL, so the URL is found by walking the response for the
# first https value; if that ever misses, the script dumps the raw JSON and stops
# rather than guess.
#
# Config (env vars, all optional; defaults reproduce the known-good create):
#   NEBIUS_IMAGE          container image ref
#                         (default: the proven POC hebrew-transcriber image)
#   NEBIUS_NAME           endpoint name         (default: hebrew-transcriber)
#   NEBIUS_PLATFORM       GPU platform          (default: gpu-l40s-a)
#                         NOTE: `create --help` lists gpu-l40s-d as an example;
#                         the POC ran on gpu-l40s-a. Confirm it in your region.
#   NEBIUS_PRESET         platform preset       (default: 1gpu-8vcpu-32gb)
#   NEBIUS_CONTAINER_PORT container listen port (default: 8000)
#   NEBIUS_DISK_SIZE      boot disk size        (default: 100Gi)
#   NEBIUS_PARENT_ID      project id            (default: the POC project;
#                         override for another account)
#   NEBIUS_ENV            container env (quality knobs), space-separated KEY=VAL
#                         (default: DEVICE=cuda COMPUTE_TYPE=float16 BEAM_SIZE=10
#                          CONDITION_ON_PREVIOUS_TEXT=true)
#   NEBIUS_EXTRA_ENV      extra container env, appended to NEBIUS_ENV (default: none)
#   WARMUP_AUDIO          path to a warmup clip (default: a generated 1s silent wav)
#   WARMUP_TIMEOUT        seconds to wait for the container to answer (default: 600)
#
# Prereqs: nebius CLI installed and authenticated (`nebius profile list` works),
# plus curl and python3.
#
# Usage: scripts/endpoint/up

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STATE_FILE="$SCRIPT_DIR/.state.json"       # our normalized {id,url,token,name}
RAW_FILE="$SCRIPT_DIR/.create.json"        # raw create/get response, for debugging
# Both are gitignored: the state file holds the data-plane token.

# ---- defaults -------------------------------------------------------------
NEBIUS_IMAGE="${NEBIUS_IMAGE:-cr.eu-north1.nebius.cloud/e00dbvmt1b3zpbpkd4/hebrew-transcriber:0.1.0}"
NEBIUS_NAME="${NEBIUS_NAME:-hebrew-transcriber}"
NEBIUS_PLATFORM="${NEBIUS_PLATFORM:-gpu-l40s-a}"
NEBIUS_PRESET="${NEBIUS_PRESET:-1gpu-8vcpu-32gb}"
NEBIUS_CONTAINER_PORT="${NEBIUS_CONTAINER_PORT:-8000}"
NEBIUS_DISK_SIZE="${NEBIUS_DISK_SIZE:-100Gi}"
NEBIUS_PARENT_ID="${NEBIUS_PARENT_ID:-project-e00mbv9spr00twx6t5saw7}"
# Quality knobs the container reads (the POC's locked GPU settings).
NEBIUS_ENV="${NEBIUS_ENV:-DEVICE=cuda COMPUTE_TYPE=float16 BEAM_SIZE=10 CONDITION_ON_PREVIOUS_TEXT=true}"
NEBIUS_EXTRA_ENV="${NEBIUS_EXTRA_ENV:-}"
WARMUP_AUDIO="${WARMUP_AUDIO:-}"
WARMUP_TIMEOUT="${WARMUP_TIMEOUT:-600}"

log()  { echo "[up] $*"; }
warn() { echo "[up] warning: $*" >&2; }
die()  { echo "[up] error: $*" >&2; exit 1; }

case "${1:-}" in
  -h|--help) grep '^#' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
  "") : ;;
  *) die "unexpected argument: $1 (this script takes no args; configure via env vars, see --help)" ;;
esac

command -v nebius  >/dev/null 2>&1 || die "nebius CLI not found. Install it and run 'nebius profile list' to confirm auth."
command -v curl    >/dev/null 2>&1 || die "curl not found."
command -v python3 >/dev/null 2>&1 || die "python3 not found."
command -v jq      >/dev/null 2>&1 || die "jq not found."

# Pull the first https:// string anywhere in a JSON document (schema-agnostic:
# a public endpoint resource carries exactly one, its managed URL).
first_https_url() { jq -r '[.. | strings | select(test("^https://"))] | (.[0] // empty)'; }

# Write the local state file (0600 -- it carries the data-plane token) so `down`
# and idempotent re-runs can find the endpoint. Args: id url token name.
save_state() {
  jq -n --arg id "$1" --arg url "$2" --arg token "$3" --arg name "$4" \
    '{id:$id, url:$url, token:$token, name:$name}' >"$STATE_FILE"
  chmod 600 "$STATE_FILE"
}

# ---- warmup helpers -------------------------------------------------------
# Warm/readiness in one: retry until the container answers on the data plane.
# 200 = transcribed; 400/413 = app is up and rejected our probe payload (still
# proof the container is serving). 000/502/503/504 = still scaling up, retry.
# 401/403/404 = misconfiguration, fail fast (retrying will not fix it).
warmup() {
  local url="$1" token="$2" clip="$3"
  local deadline=$(( SECONDS + WARMUP_TIMEOUT ))
  local body code
  body="$(mktemp)"; trap 'rm -f "$body"' RETURN
  log "warming ${url}/transcribe (up to ${WARMUP_TIMEOUT}s for the L40S to come up)..."
  while :; do
    code="$(curl -s -o "$body" -w '%{http_code}' --max-time 150 \
             -H "Authorization: Bearer ${token}" \
             -F "file=@${clip}" "${url}/transcribe" 2>/dev/null || echo 000)"
    case "$code" in
      200)
        log "warm: 200 OK (rtf=$(jq -r '.rtf // "?"' "$body" 2>/dev/null))"
        return 0 ;;
      400|413)
        log "warm: container is up (HTTP $code on the probe payload)"; return 0 ;;
      401|403)
        die "warmup got HTTP $code: token/auth is wrong for this endpoint." ;;
      404)
        die "warmup got HTTP 404: is the URL a bare base (no /transcribe)? got ${url}" ;;
      000|502|503|504)
        : ;;  # still scaling up
      *)
        warn "warmup got unexpected HTTP $code; retrying" ;;
    esac
    (( SECONDS < deadline )) || die "endpoint did not answer within ${WARMUP_TIMEOUT}s (last HTTP $code). It may still be starting; check the Nebius console."
    sleep 10
  done
}

# 1s of 16kHz mono silence -- decodes fine (not "empty input"), enough to wake
# the container and force model load. A real clip via WARMUP_AUDIO is better.
make_silence_wav() {
  local out="$1"
  python3 - "$out" <<'PY'
import sys, wave
with wave.open(sys.argv[1], "wb") as w:
    w.setnchannels(1); w.setsampwidth(2); w.setframerate(16000)
    w.writeframes(b"\x00\x00" * 16000)
PY
}

# ---- reuse an already-running endpoint ------------------------------------
if [[ -f "$STATE_FILE" ]]; then
  existing_id="$(jq -r '.id // empty' "$STATE_FILE" 2>/dev/null || true)"
  if [[ -n "$existing_id" ]] && nebius ai endpoint get --id "$existing_id" >/dev/null 2>&1; then
    token="$(jq -r '.token // empty' "$STATE_FILE")"
    url="$(jq -r '.url // empty' "$STATE_FILE")"
    [[ -n "$token" ]] || die "state file $STATE_FILE has no token; tear the endpoint down (scripts/endpoint/down) and re-run."
    # A prior run may have saved id+token but died before resolving the URL; recover it.
    if [[ -z "$url" ]]; then
      log "state file has no URL yet; re-resolving it from the endpoint..."
      nebius ai endpoint get --id "$existing_id" --format json >"$RAW_FILE" 2>/dev/null || true
      url="$(first_https_url <"$RAW_FILE" 2>/dev/null || true)"
      [[ -n "$url" ]] && save_state "$existing_id" "$url" "$token" "$(jq -r '.name // empty' "$STATE_FILE")"
    fi
    [[ -n "$url" ]] || die "could not resolve the endpoint URL (raw JSON in $RAW_FILE). Fix the URL extraction in this script, or tear down and recreate."
    log "reusing existing endpoint $existing_id (recorded in $STATE_FILE)"
    clip="$WARMUP_AUDIO"
    if [[ -z "$clip" ]]; then clip="$(mktemp --suffix=.wav)"; make_silence_wav "$clip"; fi
    warmup "$url" "$token" "$clip"
    printf '\n'
    log "ENDPOINT READY (reused)"
    log "  URL:   $url"
    log "  token: (in $STATE_FILE)"
    printf '\n\033[1;33m  *** L40S IS RUNNING AND BILLING. Delete it when done: ***\033[0m\n'
    printf '      scripts/endpoint/down        (or the Nebius web console)\n\n'
    exit 0
  fi
  warn "state file present but its endpoint is gone; creating a fresh one."
fi

# ---- create a new endpoint ------------------------------------------------
# Self-generated data-plane token (so we never have to parse it back out).
token="$(python3 -c 'import secrets; print(secrets.token_urlsafe(32))')"

create_args=(ai endpoint create
  --name "$NEBIUS_NAME"
  --image "$NEBIUS_IMAGE"
  --container-port "$NEBIUS_CONTAINER_PORT"
  --platform "$NEBIUS_PLATFORM"
  --preset "$NEBIUS_PRESET"
  --disk-size "$NEBIUS_DISK_SIZE"
  --public
  --auth token
  --token "$token"
  --format json)
[[ -n "$NEBIUS_PARENT_ID" ]] && create_args+=(--parent-id "$NEBIUS_PARENT_ID")
# shellcheck disable=SC2206
env_list=($NEBIUS_ENV $NEBIUS_EXTRA_ENV)
for kv in "${env_list[@]}"; do create_args+=(--env "$kv"); done

log "creating endpoint '$NEBIUS_NAME' on $NEBIUS_PLATFORM/$NEBIUS_PRESET from $NEBIUS_IMAGE ..."
log "(this creates a NEW billing endpoint)"
if ! nebius "${create_args[@]}" >"$RAW_FILE" 2>&1; then
  cat "$RAW_FILE" >&2
  die "nebius ai endpoint create failed (raw output above)."
fi

id="$(jq -r '.metadata.id // .id // empty' "$RAW_FILE" 2>/dev/null || true)"
url="$(first_https_url <"$RAW_FILE" 2>/dev/null || true)"

# The endpoint is now created and BILLING. Persist id+token immediately -- before
# resolving the URL, which can fail -- so a billing endpoint can never be orphaned
# ('down' needs the id) and the self-generated token is never lost.
save_state "$id" "$url" "$token" "$NEBIUS_NAME"
[[ -n "$id" ]] || warn "no endpoint id parsed; 'down' will need --id or the Nebius console."

# Networking can lag the create response; if the URL is not there yet, poll get.
if [[ -z "$url" && -n "$id" ]]; then
  log "URL not in the create response yet; polling status..."
  for _ in $(seq 1 30); do
    if nebius ai endpoint get --id "$id" --format json >"$RAW_FILE" 2>/dev/null; then
      url="$(first_https_url <"$RAW_FILE" 2>/dev/null || true)"
      [[ -n "$url" ]] && break
    fi
    sleep 10
  done
fi

if [[ -z "$url" ]]; then
  echo "----- raw Nebius response ($RAW_FILE) -----" >&2
  cat "$RAW_FILE" >&2
  echo "-------------------------------------------" >&2
  die "endpoint created and BILLING, but its URL was not found in the response above. Its id+token are saved in $STATE_FILE, so scripts/endpoint/down can tear it down and re-running up will retry the URL. Fix the URL extraction to match the field shown, or tear it down."
fi

save_state "$id" "$url" "$token" "$NEBIUS_NAME"
log "endpoint id: ${id:-<unknown>}  url: $url"

# ---- warm it --------------------------------------------------------------
clip="$WARMUP_AUDIO"
if [[ -z "$clip" ]]; then clip="$(mktemp --suffix=.wav)"; make_silence_wav "$clip"; fi
warmup "$url" "$token" "$clip"

# ---- summary + billing reminder -------------------------------------------
printf '\n'
log "ENDPOINT READY"
log "  URL:   $url"
log "  token: (saved in $STATE_FILE, chmod 600)"
log "  id:    ${id:-<unknown>}"
printf '\nPut the URL + token into Secret Manager for the backend; both change on every (re)create.\n'
printf '\033[1;33m  *** L40S IS NOW RUNNING AND BILLING. Delete it when done: ***\033[0m\n'
printf '      scripts/endpoint/down        (or the Nebius web console)\n\n'
