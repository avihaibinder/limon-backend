# Copy to .env and adjust as needed. All variables are prefixed with LIMON_.
LIMON_DEBUG=false
LIMON_DATABASE_URL=sqlite+aiosqlite:///./limon.db
# JSON list of allowed CORS origins; use ["*"] for local development.
LIMON_CORS_ORIGINS=["*"]
# Supabase project URL — bearer tokens are verified against its JWKS endpoint.
LIMON_SUPABASE_URL=https://your-project-ref.supabase.co
# Only needed for legacy Supabase projects still signing tokens with HS256.
# LIMON_SUPABASE_JWT_SECRET=
# Private Google Cloud Storage bucket used for voice notes and generated files.
# Cloud Run authenticates through its runtime service account (no key file).
LIMON_GCS_BUCKET=your-private-bucket-name
