# Copy to .env and adjust as needed. All variables are prefixed with LIMON_.
LIMON_DEBUG=false
LIMON_DATABASE_URL=sqlite+aiosqlite:///./limon.db
# JSON list of allowed CORS origins; use ["*"] for local development.
LIMON_CORS_ORIGINS=["*"]
# Supabase project URL — bearer tokens are verified against its JWKS endpoint.
LIMON_SUPABASE_URL=https://your-project-ref.supabase.co
# Only needed for legacy Supabase projects still signing tokens with HS256.
# LIMON_SUPABASE_JWT_SECRET=

# Google Cloud Storage — target bucket for audio upload presign URLs.
# Unset => the uploads endpoint returns 503. Uses Application Default
# Credentials (run: gcloud auth application-default login).
# LIMON_GCS_BUCKET=limon-dev-<you>
# Service account whose identity signs the upload URLs (via IAM signBlob).
# LIMON_GCS_SIGNER_SERVICE_ACCOUNT=limon-signer@<project>.iam.gserviceaccount.com
# How long a presigned upload URL stays valid (seconds; default 900 = 15 min).
# LIMON_GCS_SIGNED_URL_TTL_SECONDS=900
